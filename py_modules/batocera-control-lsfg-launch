#!/bin/bash
# BATOCERA_CONTROL_LSFG_LAUNCH
set -e

appid=""
if [ "${1:-}" = "--appid" ] && [[ "${2:-}" =~ ^[0-9]+$ ]]; then
    appid="$2"
    shift 2
fi

[ "$#" -gt 0 ] || exit 2

config="${BATOCERA_CONTROL_LSFG_CONFIG:-/userdata/system/configs/batocera-control/lsfg.env}"
[ -n "${appid}" ] && [ -r "${config}" ] || exec "$@"

# Generated by the Batocera Control plugin from validated scalar values.
# shellcheck disable=SC1090
. "${config}"

case " ${BATOCERA_LSFG_ENABLED_APPIDS:-} " in
    *" ${appid} "*) ;;
    *) exec "$@" ;;
esac

[ -f "${LSFG_DLL_PATH:-}" ] || exec "$@"
layer_root="${BATOCERA_LSFG_LAYER_ROOT:-}"
layer_library="${layer_root}/lib/liblsfg-vk.so"
layer_path="${layer_root}/share/vulkan/explicit_layer.d"
[ -f "${layer_library}" ] && [ -d "${layer_path}" ] || exec "$@"

append_colon_value() {
    local name="$1" value="$2" current item output=""
    current="${!name:-}"
    IFS=: read -r -a items <<< "${current}"
    for item in "${items[@]}"; do
        [ -n "${item}" ] || continue
        [ "${item}" = "${value}" ] && continue
        output+="${output:+:}${item}"
    done
    printf -v "${name}" '%s' "${value}${output:+:${output}}"
    export "${name}"
}

export ENABLE_LSFG=1
export LSFG_LEGACY=1
export LSFG_DLL_PATH
export LSFG_MULTIPLIER
export LSFG_FLOW_SCALE
export LSFG_PERFORMANCE_MODE
export LSFG_HDR_MODE
if [ -n "${BATOCERA_LSFG_PRESENT_MODE:-}" ]; then
    export LSFG_EXPERIMENTAL_PRESENT_MODE="${BATOCERA_LSFG_PRESENT_MODE}"
else
    unset LSFG_EXPERIMENTAL_PRESENT_MODE
fi

append_colon_value VK_INSTANCE_LAYERS VK_LAYER_LS_frame_generation
append_colon_value VK_LAYER_PATH "${layer_path}"
append_colon_value LD_LIBRARY_PATH "${layer_root}/lib"

exec "$@"
